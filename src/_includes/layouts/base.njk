<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle or (title + " – Digital Toolkit – GovTech Barbados") }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="icon" type="image/png" href="/flag_of_barbados.png">
</head>
<body>

  {% include "partials/official-banner.njk" %}

  <header class="site-header">
    <div class="container">
      {% if isHome %}
      <div class="site-header__logo">
        {% include "partials/logo.njk" %}
      </div>
      {% else %}
      <a href="/" class="site-header__logo">
        {% include "partials/logo.njk" %}
      </a>
      {% endif %}
    </div>
  </header>

  {% include "partials/phase-banner.njk" %}

  {{ content | safe }}

  {% include "partials/site-footer.njk" %}

</body>
</html>
