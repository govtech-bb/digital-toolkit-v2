---
layout: layouts/base.njk
isHome: true
pageTitle: "Digital Toolkit – GovTech Barbados"
---
<section class="hero">
  <div class="container">
    <h1>{{ heroTitle }}</h1>
    {% if lastUpdated %}<p class="hero__subtitle">Last updated {{ lastUpdated }}</p>{% endif %}
    <hr class="hero__rule">
    <p class="hero__lede">{{ lede | safe }}</p>
  </div>
</section>

<main class="main-content">
  <div class="container">

    {% for section in sections %}
    <section class="toolkit-section">
      <h2 class="toolkit-section__heading">{{ section.heading }}</h2>
      <p class="toolkit-section__desc">{{ section.desc }}</p>
      <ul class="resource-list">
        {% for item in section.items %}
          {% set entry = collections.all | pageByPath(item.page) %}
          {% set itemTitle = entry.data.title if entry else item.title %}
          {% set itemHref  = entry.url        if entry else item.href %}
          {% set itemDesc  = entry.data.lede  if entry else item.desc %}
        <li class="resource-item">
          <a class="resource-item__link" href="{{ itemHref }}">{{ itemTitle }}</a>
          {% if item.tag %}<span class="tag tag--{{ item.tag.variant }}">{{ item.tag.label }}</span>{% endif %}
          <p class="resource-item__desc">{{ itemDesc | safe }}</p>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endfor %}

    {% if cta %}
    <div class="cta-panel">
      <h2>{{ cta.heading }}</h2>
      <p>{{ cta.body | safe }}</p>
      <a class="button" href="{{ cta.href }}">{{ cta.label }}</a>
    </div>
    {% endif %}

  </div>
</main>
